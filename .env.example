# --- Database -----------------------------------------------------------------
# Dev (bare-bun or docker compose): use localhost or the qr-postgres container.
# docker-compose.yml overrides this to postgres://...@qr-postgres:5432/...
# Homelab:  set to your external Postgres DSN (e.g. postgres://...@192.168.1.10:5432/...)
DATABASE_URL=postgres://queue_reminiscence:queue_reminiscence@localhost:5432/queue_reminiscence

# --- Application URLs --------------------------------------------------------
# Dev:     http://localhost:3000 / http://localhost:3001 / http://localhost:3002
# Homelab: https://queue.example.com / https://queue-admin.example.com / https://queue-api.example.com
PUBLIC_APP_URL=http://localhost:3000
ADMIN_APP_URL=http://localhost:3001
API_PUBLIC_BASE_URL=http://localhost:3002/api
API_ADMIN_BASE_URL=http://localhost:3002/api

# --- Secrets -----------------------------------------------------------------
# Generate each with:  openssl rand -hex 32
SESSION_SECRET=change-me-in-development
TOKEN_HMAC_SECRET=change-me-in-development
RATE_LIMIT_HMAC_SECRET=change-me-in-development

# --- Proxy -------------------------------------------------------------------
# Set to true when a reverse proxy (e.g. Traefik) terminates TLS in front of
# the API. Required for correct rate-limit IPs and Secure cookie behavior.
# Leave false for local dev (docker compose) and bare-bun.
TRUST_PROXY=false

# --- Session lifetimes -------------------------------------------------------
ADMIN_SESSION_TTL_DAYS=14
PUBLIC_MUTATION_SESSION_TTL_HOURS=8

# --- Seed script (bootstrap only) --------------------------------------------
# GHCR deployments seed only when RUN_SEED=true. Keep false after bootstrap so
# deleted demo org/venue/board records are not recreated on every API restart.
RUN_SEED=false
SEED_ADMIN_EMAIL=admin@example.com
SEED_ADMIN_PASSWORD=change-me-in-development
# Set to true only for bootstrap to promote the seeded admin to super-admin.
# Intentionally unset in production after initial setup.
# SEED_SUPER_ADMIN=false
