{
  "name": "queue-reminiscence",
  "private": true,
  "packageManager": "bun@1.2.23",
  "type": "module",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev:api": "bun --env-file=.env --watch apps/api/src/index.ts",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit --project tsconfig.json",
    "test": "bun test apps packages --pass-with-no-tests",
    "check": "bun run format:check && bun run lint && bun run typecheck && bun run test",
    "install:check": "bun install --frozen-lockfile",
    "e2e": "playwright test",
    "e2e:install": "playwright install chromium --with-deps",
    "docker:up": "docker compose up --build -d",
    "docker:down": "docker compose down"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.49.0",
    "@types/node": "^24.3.0",
    "eslint": "^10.5.0",
    "prettier": "^3.8.4",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.61.0"
  }
}
